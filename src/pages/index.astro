---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Marquee1909 from '../components/Marquee1909.astro';
import Match from '../components/Match.astro';
import Events from '../components/Events.astro';
import News from '../components/News.astro';
import History from '../components/History.astro';
import Team from '../components/Team.astro';
import Club from '../components/Club.astro';
import Membership from '../components/Membership.astro';
import Partners from '../components/Partners.astro';
import Contacts from '../components/Contacts.astro';
import Footer from '../components/Footer.astro';
import PaymentDemo from '../components/PaymentDemo.astro';
---
<Layout>
  <Nav />
  <main>
    <Hero />
    <Marquee1909 />
    <Match />
    <Events />
    <News />
    <History />
    <Team />
    <Club />
    {/* <Membership /> — временно скрыто до согласования Т-Кассы с администрацией клуба */}
    <Contacts />
    <Partners />
  </main>
  <Footer />
  {/* <PaymentDemo /> — скрыто вместе с секцией членства */}
</Layout>
