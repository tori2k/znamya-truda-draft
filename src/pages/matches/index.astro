---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { fetchNextEvent, parseMatchTeams, isHomeMatch, formatMatchDate, formatMatchTime } from '../../lib/timepad';
import { FFMO_TOURNAMENT_URL, RESULT_LABELS, TIMEPAD_CLUB_URL, lastMatches } from '../../lib/matches';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const LOGO = `${BASE}/logo.png`;
const asset = (p: string) => `${BASE}${p.startsWith('/') ? p : '/' + p}`;

const reports = (await getCollection('news', ({ data }) => {
  return (import.meta.env.DEV || !data.draft) && data.category === 'Матчи';
})).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const opponentEntries = await getCollection('opponents');
const opponentLogo = (teamName: string): string | null => {
  const lc = teamName.toLowerCase();
  const found = opponentEntries.find((e) =>
    lc.includes(e.data.name.toLowerCase()) || e.data.name.toLowerCase().includes(lc),
  );
  if (!found || !found.data.logo) return null;
  return asset(found.data.logo);
};

const isOurTeam = (name: string) => /знамя труда/i.test(name);
const shortName = (name: string) => {
  const words = name
    .replace(/[«»"']/g, '')
    .split(/[\s\-]+/)
    .filter((w) => w && !/^фк$/i.test(w));
  if (words.length >= 2) return words.map((w) => w[0]).join('').toUpperCase().slice(0, 4);
  return (words[0] || name).slice(0, 3).toUpperCase();
};
const crestFor = (teamName: string) => isOurTeam(teamName) ? LOGO : opponentLogo(teamName);

const tpEvent = await fetchNextEvent();
const fallbackNext = {
  league: 'ФФМО · Б-2',
  dateText: 'дата уточняется',
  time: 'время уточняется',
  homeName: 'Знамя Труда',
  awayName: 'Соперник',
  venue: 'Стадион «Знамя Труда», Орехово-Зуево',
  url: TIMEPAD_CLUB_URL,
};

let nextMatch = fallbackNext;
if (tpEvent) {
  const teams = parseMatchTeams(tpEvent.name);
  const home = teams ? teams.home : 'Знамя Труда';
  const away = teams ? teams.away : tpEvent.name;
  const homeIsKlub = isHomeMatch(tpEvent);
  const venue = [tpEvent.location.address, tpEvent.location.city].filter(Boolean).join(', ');

  nextMatch = {
    league: 'ФФМО · Б-2',
    dateText: formatMatchDate(tpEvent.startsAt),
    time: formatMatchTime(tpEvent.startsAt),
    homeName: homeIsKlub ? 'Знамя Труда' : home,
    awayName: homeIsKlub ? away : 'Знамя Труда',
    venue,
    url: tpEvent.url,
  };
}

const rows = [
  {
    status: 'upcoming',
    date: nextMatch.dateText,
    time: nextMatch.time,
    league: nextMatch.league,
    homeName: nextMatch.homeName,
    awayName: nextMatch.awayName,
    score: 'VS',
    href: nextMatch.url,
    cta: 'Регистрация',
  },
  ...lastMatches.map((m) => ({
    status: 'played',
    date: m.dateText,
    time: RESULT_LABELS[m.result],
    league: m.league,
    homeName: m.home.name,
    awayName: m.away.name,
    score: `${m.home.score}:${m.away.score}`,
    href: m.reportSlug ? `${BASE}/news/${m.reportSlug}/` : '',
    cta: 'Отчёт',
  })),
];

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long' }).format(d);
const newsUrl = (n: { id: string; data: { slug?: string } }) =>
  `${BASE}/news/${n.data.slug || n.id}/`;
---
<Layout title="Матчи — ФК «Знамя Труда»" description="Расписание, результаты и отчеты матчей ФК «Знамя Труда» Орехово-Зуево.">
  <Nav />

  <main class="matches-page">
    <section class="matches-hero">
      <div class="container-x">
        <div class="matches-hero__head">
          <div class="sec-tag">Матчи</div>
          <h1 class="matches-hero__title">РАСПИСАНИЕ<br/><span>И РЕЗУЛЬТАТЫ</span></h1>
          <p class="matches-hero__lead">
            Ближайшие игры, результаты прошедших матчей, отчеты и регистрация на домашние встречи клуба.
          </p>
        </div>

        <div class="next-match">
          <div class="next-match__meta">
            <span>Ближайший матч</span>
            <strong>{nextMatch.league}</strong>
          </div>

          <div class="next-match__teams">
            <div class="next-match__team">
              <span class="next-match__crest">
                {crestFor(nextMatch.homeName) ? (
                  <img src={crestFor(nextMatch.homeName)!} alt={nextMatch.homeName} />
                ) : (
                  shortName(nextMatch.homeName)
                )}
              </span>
              <span>{nextMatch.homeName}</span>
            </div>
            <div class="next-match__vs">
              <strong>{nextMatch.dateText}</strong>
              <span>{nextMatch.time}</span>
              <em>VS</em>
            </div>
            <div class="next-match__team next-match__team--right">
              <span class="next-match__crest">
                {crestFor(nextMatch.awayName) ? (
                  <img src={crestFor(nextMatch.awayName)!} alt={nextMatch.awayName} />
                ) : (
                  shortName(nextMatch.awayName)
                )}
              </span>
              <span>{nextMatch.awayName}</span>
            </div>
          </div>

          <div class="next-match__bottom">
            <span>{nextMatch.venue}</span>
            <a href={nextMatch.url} target="_blank" rel="noopener" class="btn btn--red">Регистрация</a>
          </div>
        </div>
      </div>
    </section>

    <section class="matches-list">
      <div class="container-x">
        <div class="matches-list__head">
          <h2>Матч-центр</h2>
          <div class="matches-list__links">
            <a href={FFMO_TOURNAMENT_URL} target="_blank" rel="noopener">Календарь ФФМО</a>
            <a href={TIMEPAD_CLUB_URL} target="_blank" rel="noopener">Timepad клуба</a>
          </div>
        </div>

        <div class="match-table">
          {rows.map((row) => (
            <article class={`match-row match-row--${row.status}`}>
              <div class="match-row__date">
                <strong>{row.date}</strong>
                <span>{row.time}</span>
              </div>
              <div class="match-row__teams">
                <div class="match-row__team">
                  <span class="match-row__crest">
                    {crestFor(row.homeName) ? <img src={crestFor(row.homeName)!} alt={row.homeName} /> : shortName(row.homeName)}
                  </span>
                  <span>{row.homeName}</span>
                </div>
                <div class="match-row__score">{row.score}</div>
                <div class="match-row__team match-row__team--right">
                  <span class="match-row__crest">
                    {crestFor(row.awayName) ? <img src={crestFor(row.awayName)!} alt={row.awayName} /> : shortName(row.awayName)}
                  </span>
                  <span>{row.awayName}</span>
                </div>
              </div>
              {row.href && (
                <a href={row.href} target={row.href.startsWith('http') ? '_blank' : undefined} rel={row.href.startsWith('http') ? 'noopener' : undefined} class="match-row__action">
                  {row.cta}
                </a>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="match-reports">
      <div class="container-x">
        <div class="match-reports__head">
          <div class="sec-tag">Отчеты</div>
          <h2>Материалы по матчам</h2>
        </div>

        <div class="report-grid">
          {reports.map((n) => (
            <a href={newsUrl(n)} class="report-card">
              {n.data.image && (
                <div class="report-card__img">
                  <img src={asset(n.data.image)} alt={n.data.title} loading="lazy" />
                  {n.data.score && <span class="report-card__score">{n.data.score}</span>}
                </div>
              )}
              <div class="report-card__body">
                <div class="report-card__meta">{fmtDate(n.data.date)}</div>
                <h3>{n.data.title}</h3>
                <p>{n.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .matches-page {
    background: #fafaf7;
    min-height: 80vh;
  }
  .matches-hero {
    padding: 130px 0 56px;
  }
  .matches-hero__head {
    max-width: 820px;
    margin-bottom: 36px;
  }
  .matches-hero__title {
    margin: 0;
    font-family: 'Onest', sans-serif;
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900;
    line-height: 0.92;
    text-transform: uppercase;
    color: #0a0a0a;
  }
  .matches-hero__title span { color: #E4002B; }
  .matches-hero__lead {
    max-width: 620px;
    margin: 22px 0 0;
    font-size: 16px;
    line-height: 1.7;
    color: #4a4a4a;
  }

  .next-match {
    padding: 34px;
    background: linear-gradient(135deg, #E4002B 0%, #8a0019 100%);
    color: #fff;
    border-radius: 8px;
    box-shadow: 0 20px 50px rgba(228,0,43,0.2);
  }
  .next-match__meta {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.78);
  }
  .next-match__meta strong { color: #fff; font-weight: 700; }
  .next-match__teams {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 24px;
  }
  .next-match__team {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
    font-family: 'Onest', sans-serif;
    font-size: clamp(18px, 3vw, 34px);
    font-weight: 900;
    text-transform: uppercase;
  }
  .next-match__team--right {
    justify-content: flex-end;
    text-align: right;
  }
  .next-match__crest {
    width: 72px;
    height: 72px;
    flex: 0 0 72px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255,255,255,0.16);
    font-size: 16px;
    font-weight: 900;
  }
  .next-match__crest img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .next-match__vs {
    text-align: center;
    min-width: 120px;
  }
  .next-match__vs strong,
  .next-match__vs span,
  .next-match__vs em {
    display: block;
  }
  .next-match__vs strong {
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .next-match__vs span {
    margin-top: 6px;
    font-family: 'Onest', sans-serif;
    font-size: 34px;
    font-weight: 900;
  }
  .next-match__vs em {
    margin-top: 6px;
    font-size: 11px;
    font-style: normal;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.68);
  }
  .next-match__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 30px;
    padding-top: 22px;
    border-top: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.8);
    font-size: 13px;
  }
  .next-match__bottom .btn {
    background: #fff;
    color: #E4002B;
  }

  .matches-list {
    padding: 40px 0 64px;
  }
  .matches-list__head,
  .match-reports__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 24px;
  }
  .matches-list__head h2,
  .match-reports__head h2 {
    margin: 0;
    font-family: 'Onest', sans-serif;
    font-size: clamp(30px, 4vw, 54px);
    font-weight: 900;
    text-transform: uppercase;
    color: #0a0a0a;
  }
  .matches-list__links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .matches-list__links a {
    padding: 10px 14px;
    border: 1px solid rgba(0,0,0,0.14);
    border-radius: 8px;
    background: #fff;
    color: #0a0a0a;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.6px;
    text-transform: uppercase;
    text-decoration: none;
  }
  .match-table {
    display: grid;
    gap: 12px;
  }
  .match-row {
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr) 132px;
    align-items: center;
    gap: 22px;
    padding: 20px;
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
  }
  .match-row--upcoming { border-color: rgba(228,0,43,0.25); }
  .match-row__date strong {
    display: block;
    font-family: 'Onest', sans-serif;
    font-size: 24px;
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
    color: #0a0a0a;
  }
  .match-row__date span {
    display: block;
    margin-top: 7px;
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: #777;
  }
  .match-row__teams {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 74px minmax(0, 1fr);
    align-items: center;
    gap: 14px;
  }
  .match-row__team {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    font-family: 'Onest', sans-serif;
    font-size: 15px;
    font-weight: 800;
    color: #0a0a0a;
  }
  .match-row__team--right {
    justify-content: flex-end;
    text-align: right;
  }
  .match-row__crest {
    width: 38px;
    height: 38px;
    flex: 0 0 38px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(228,0,43,0.08);
    color: #E4002B;
    font-size: 10px;
    font-weight: 900;
  }
  .match-row__crest img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .match-row__score {
    font-family: 'Onest', sans-serif;
    font-size: 24px;
    font-weight: 900;
    text-align: center;
    color: #0a0a0a;
  }
  .match-row__action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px 14px;
    border-radius: 8px;
    background: #0a0a0a;
    color: #fff;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    text-decoration: none;
  }

  .match-reports {
    padding: 64px 0 120px;
    background: #fff;
  }
  .match-reports__head {
    align-items: flex-start;
    flex-direction: column;
    gap: 4px;
  }
  .report-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .report-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    background: #fafaf7;
    color: inherit;
    text-decoration: none;
    transition: transform 0.25s, border-color 0.25s;
  }
  .report-card:hover {
    transform: translateY(-4px);
    border-color: rgba(228,0,43,0.32);
  }
  .report-card__img {
    position: relative;
    aspect-ratio: 16 / 10;
    background: #eee;
  }
  .report-card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .report-card__score {
    position: absolute;
    top: 14px;
    right: 16px;
    font-family: 'Onest', sans-serif;
    font-size: 34px;
    font-weight: 900;
    color: #fff;
    text-shadow: 0 4px 18px rgba(0,0,0,0.4);
  }
  .report-card__body {
    padding: 20px;
  }
  .report-card__meta {
    margin-bottom: 9px;
    font-size: 11px;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: #E4002B;
  }
  .report-card h3 {
    margin: 0 0 10px;
    font-family: 'Onest', sans-serif;
    font-size: 18px;
    line-height: 1.25;
    color: #0a0a0a;
  }
  .report-card p {
    margin: 0;
    font-size: 13px;
    line-height: 1.55;
    color: #4a4a4a;
  }

  @media (max-width: 900px) {
    .matches-hero { padding: 100px 0 42px; }
    .next-match,
    .match-row { padding: 22px; }
    .next-match__meta,
    .next-match__bottom,
    .matches-list__head {
      flex-direction: column;
      align-items: flex-start;
    }
    .next-match__teams {
      grid-template-columns: minmax(0, 1fr) 58px minmax(0, 1fr);
      gap: 10px;
    }
    .next-match__team {
      flex-direction: column;
      justify-content: center;
      text-align: center;
      font-size: 13px;
      gap: 8px;
    }
    .next-match__crest {
      width: 52px;
      height: 52px;
      flex-basis: 52px;
    }
    .next-match__vs {
      min-width: 0;
    }
    .next-match__vs strong { font-size: 10px; }
    .next-match__vs span { font-size: 20px; }
    .match-row {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .match-row__teams {
      grid-template-columns: minmax(0, 1fr) 56px minmax(0, 1fr);
      gap: 8px;
    }
    .match-row__team {
      flex-direction: column;
      justify-content: center;
      text-align: center;
      font-size: 12px;
      gap: 6px;
    }
    .match-row__crest {
      width: 32px;
      height: 32px;
      flex-basis: 32px;
    }
    .match-row__score { font-size: 18px; }
    .match-row__action { width: 100%; }
    .report-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 1100px) and (min-width: 901px) {
    .report-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
