---
// Меню генератора баннеров для соцсетей. НЕ часть сайта — служебная
// страница, только локально (npm run dev → http://localhost:4321/banner).
import '../styles/global.css';
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (p: string) => `${BASE}${p.startsWith('/') ? p : '/' + p}`;
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Баннеры для соцсетей — Знамя Труда</title>
  <link href="https://fonts.googleapis.com/css2?family=Onest:wght@400;700;900&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      min-height: 100vh;
      background: linear-gradient(135deg, #E4002B 0%, #8a0019 100%);
      color: #fff;
      font-family: 'Onest', sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 50px;
      padding: 40px;
    }
    .head { text-align: center; }
    .head img { height: 90px; margin-bottom: 24px; }
    .head h1 {
      font-size: 44px; font-weight: 900;
      text-transform: uppercase; letter-spacing: -0.01em;
    }
    .head p { font-size: 18px; opacity: 0.8; margin-top: 10px; }
    .cards { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; }
    a.card {
      width: 320px;
      background: rgba(255,255,255,0.1);
      border: 2px solid rgba(255,255,255,0.25);
      border-radius: 16px;
      padding: 40px 36px;
      text-decoration: none;
      color: #fff;
      transition: all 0.2s;
    }
    a.card:hover {
      background: rgba(255,255,255,0.18);
      border-color: rgba(255,255,255,0.5);
      transform: translateY(-4px);
    }
    a.card .ic { font-size: 48px; margin-bottom: 18px; }
    a.card h2 { font-size: 28px; font-weight: 900; text-transform: uppercase; }
    a.card p { font-size: 15px; opacity: 0.8; margin-top: 10px; line-height: 1.4; }
  </style>
</head>
<body>
  <div class="head">
    <img src={asset('/logo-on-red.png')} alt="Знамя Труда" />
    <h1>Баннеры для соцсетей</h1>
    <p>Выбери шаблон → заполни → скачай PNG 1080×1080</p>
  </div>

  <div class="cards">
    <a class="card" href={`${BASE}/banner-match`}>
      <div class="ic">⚽</div>
      <h2>Анонс матча</h2>
      <p>Знамя Труда vs соперник. Соперник, дата, время, дома/выезд. Лого подтягивается само.</p>
    </a>
    <a class="card" href={`${BASE}/banner-site`}>
      <div class="ic">🌐</div>
      <h2>Анонс сайта</h2>
      <p>Запуск официального сайта fczt1909.ru с перечнем разделов.</p>
    </a>
  </div>
</body>
</html>
