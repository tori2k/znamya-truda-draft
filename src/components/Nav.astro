---
const items = [
  { href: '#match', label: 'Матчи' },
  { href: '#news', label: 'Новости' },
  { href: '#history', label: 'История' },
  { href: '#team', label: 'Команда' },
  { href: '#membership', label: 'Клуб' },
  { href: '#contacts', label: 'Контакты' },
];
---
<nav class="nav">
  <div class="container-x nav__inner">
    <a href="#" class="nav__logo" aria-label="ФК Знамя Труда — Главная">
      <div class="logo">
        <div class="logo__shield">
          <span class="logo__year">1909</span>
        </div>
        <div class="logo__text">
          <span class="logo__name">Знамя Труда</span>
          <span class="logo__city">Орехово-Зуево</span>
        </div>
      </div>
    </a>

    <ul class="nav__links">
      {items.map((i) => (
        <li><a href={i.href}>{i.label}</a></li>
      ))}
    </ul>

    <a href="#membership" class="btn btn--red nav__cta">Вступить в клуб</a>

    <button class="nav__burger" id="navBurger" aria-label="Меню">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="nav__mobile" id="navMobile">
    {items.map((i) => (
      <a href={i.href}>{i.label}</a>
    ))}
    <a href="#membership" class="btn btn--red">Вступить в клуб</a>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    backdrop-filter: blur(20px);
    background: rgba(10,10,10,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 24px;
  }
  .nav__logo { text-decoration: none; color: inherit; flex-shrink: 0; }
  .logo { display: flex; align-items: center; gap: 12px; }
  .logo__shield {
    position: relative;
    width: 44px; height: 52px;
    background: #E4002B;
    clip-path: polygon(0 0, 100% 0, 100% 70%, 50% 100%, 0 70%);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo__year {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 1px;
    color: #fff;
    margin-top: -6px;
  }
  .logo__text { display: flex; flex-direction: column; line-height: 1; }
  .logo__name {
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }
  .logo__city {
    font-size: 10px;
    color: #9a9a9a;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 3px;
  }

  .nav__links {
    display: flex; gap: 32px; list-style: none; margin: 0; padding: 0;
  }
  .nav__links a {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #d8d8d8;
    text-decoration: none;
    transition: color 0.2s;
    position: relative;
    padding: 4px 0;
  }
  .nav__links a:hover { color: #E4002B; }
  .nav__links a::after {
    content: '';
    position: absolute;
    left: 0; bottom: -2px;
    width: 0; height: 2px;
    background: #E4002B;
    transition: width 0.3s;
  }
  .nav__links a:hover::after { width: 100%; }

  .nav__cta { flex-shrink: 0; }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }
  .nav__burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: all 0.3s;
  }

  .nav__mobile {
    position: absolute;
    top: 100%; left: 0; right: 0;
    background: rgba(10,10,10,0.98);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255,255,255,0.05);
    flex-direction: column;
    padding: 20px 24px 32px;
    gap: 14px;
    display: none;
  }
  .nav__mobile.open { display: flex; }
  .nav__mobile a {
    font-family: 'Oswald', sans-serif;
    font-weight: 500;
    font-size: 16px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #d8d8d8;
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav__mobile .btn { margin-top: 12px; }

  @media (max-width: 900px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
  }
</style>

<script>
  const burger = document.getElementById('navBurger');
  const mobile = document.getElementById('navMobile');
  burger?.addEventListener('click', () => {
    mobile?.classList.toggle('open');
  });
  mobile?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => mobile.classList.remove('open'));
  });
</script>
