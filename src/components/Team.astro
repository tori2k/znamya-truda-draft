---
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const asset = (path: string) => `${BASE}${path.startsWith('/') ? path : '/' + path}`;

const staff = [
  {
    name: 'Роман Федотов',
    role: 'Главный тренер',
    photo: '/team/fedotov.jpg',
    bio: 'Воспитанник клуба, отыграл 7 сезонов в основном составе.',
  },
  {
    name: 'Дмитрий Пинин',
    role: 'Тренер',
    photo: '/team/pinin.jpg',
    bio: null,
  },
  {
    name: 'Александр Кузнецов',
    role: 'Директор клуба',
    photo: '/team/kuznetsov.jpg',
    bio: null,
  },
];

// Сокращение амплуа
const r = (full: string) => ({
  'Вратарь': 'GK',
  'Защитник': 'DF',
  'Полузащитник': 'MF',
  'Нападающий': 'FW',
} as Record<string, string>)[full] || full;

// Состав ФК «Знамя Труда» — данные с ffmo.ru
const squad = [
  { num:  1, last: 'Заборовский', first: 'Иван',      age: 21, role: 'Вратарь',      photo: '/team/zaborovsky.jpg' },
  { num:  2, last: 'Чикин',       first: 'Александр', age: 19, role: 'Защитник',     photo: null },
  { num:  5, last: 'Копылов',     first: 'Максим',    age: 22, role: 'Защитник',     photo: '/team/kopylov.jpg' },
  { num:  6, last: 'Лёвин',       first: 'Александр', age: 34, role: 'Нападающий',   photo: '/team/levin.jpg' },
  { num:  7, last: 'Шлепанов',    first: 'Даниил',    age: 37, role: 'Нападающий',   photo: null },
  { num:  8, last: 'Коробов',     first: 'Никита',    age: 26, role: 'Полузащитник', photo: '/team/korobov.jpg' },
  { num: 10, last: 'Урхов',       first: 'Роман',     age: 30, role: 'Полузащитник', photo: '/team/urkhov.jpg' },
  { num: 11, last: 'Субботин',    first: 'Евгений',   age: 26, role: 'Полузащитник', photo: '/team/subbotin.jpg' },
  { num: 13, last: 'Любченко',    first: 'Олег',      age: 20, role: 'Защитник',     photo: '/team/lyubchenko.jpg' },
  { num: 17, last: 'Канаев',      first: 'Михаил',    age: 36, role: 'Полузащитник', photo: '/team/kanaev.jpg' },
  { num: 19, last: 'Степанов',    first: 'Александр', age: 27, role: 'Полузащитник', photo: null },
  { num: 20, last: 'Малания',     first: 'Диего',     age: 35, role: 'Защитник',     photo: '/team/malania.jpg' },
  { num: 22, last: 'Харланов',    first: 'Ярослав',   age: 28, role: 'Защитник',     photo: '/team/kharlanov.jpg' },
  { num: 23, last: 'Каминецкий',  first: 'Михаил',    age: 18, role: 'Вратарь',      photo: null },
  { num: 27, last: 'Бекулов',     first: 'Сагит',     age: 26, role: 'Защитник',     photo: '/team/bekulov.jpg' },
  { num: 71, last: 'Марков',      first: 'Владимир',  age: 28, role: 'Полузащитник', photo: null },
  { num: 77, last: 'Сёмушкин',    first: 'Никита',    age: 20, role: 'Полузащитник', photo: null },
  { num: 88, last: 'Черкасов',    first: 'Данила',    age: 25, role: 'Полузащитник', photo: '/team/cherkasov.jpg' },
  { num: 93, last: 'Денисов',     first: 'Андрей',    age: 32, role: 'Защитник',     photo: null },
  { num: 97, last: 'Герасимов',   first: 'Иван',      age: 21, role: 'Защитник',     photo: '/team/gerasimov.jpg' },
];

const groups = [
  { title: 'Вратари',       items: squad.filter((p) => p.role === 'Вратарь') },
  { title: 'Защитники',     items: squad.filter((p) => p.role === 'Защитник') },
  { title: 'Полузащитники', items: squad.filter((p) => p.role === 'Полузащитник') },
  { title: 'Нападающие',    items: squad.filter((p) => p.role === 'Нападающий') },
];
---
<section class="team" id="team">
  <div class="container-x">
    <div class="team__head reveal">
      <div class="sec-tag">Команда</div>
      <h2 class="team__title">
        НАША<br/>
        <span>КОМАНДА</span>
      </h2>
      <p class="team__lead">
        Тренерский штаб и основной состав «Знамени Труда» — сезон&nbsp;2025/26, Лига&nbsp;Б-2 ФФМО.
      </p>
    </div>

    <!-- Staff -->
    <div class="staff">
      {staff.map((s, i) => (
        <article class="staff__card reveal" style={`transition-delay: ${i * 0.08}s`}>
          <div class="staff__photo">
            {s.photo ? (
              <img src={asset(s.photo)} alt={s.name} loading="lazy" />
            ) : (
              <div class="placeholder">
                <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <circle cx="12" cy="8" r="4"/>
                  <path d="M4 21c0-4 4-6 8-6s8 2 8 6"/>
                </svg>
              </div>
            )}
            <div class="staff__accent"></div>
          </div>
          <div class="staff__body">
            <div class="staff__role">{s.role}</div>
            <h3 class="staff__name">{s.name}</h3>
            {s.bio && <p class="staff__bio">{s.bio}</p>}
          </div>
        </article>
      ))}
    </div>

    <!-- Squad by role -->
    <div class="squad">
      <div class="squad__head reveal">
        <h3 class="squad__title">Основной состав</h3>
        <p class="squad__note">{squad.length} игроков · сезон 2025/26</p>
      </div>

      {groups.map((g) => (
        <div class="group">
          <h4 class="group__title reveal">{g.title} <span>({g.items.length})</span></h4>
          <div class="squad__grid">
            {g.items.map((p, i) => (
              <article class="player reveal" style={`transition-delay: ${i * 0.04}s`}>
                <div class="player__photo">
                  <div class="player__num">{p.num}</div>
                  {p.photo ? (
                    <img src={asset(p.photo)} alt={`${p.last} ${p.first}`} loading="lazy" />
                  ) : (
                    <div class="player__placeholder">
                      <svg width="70" height="70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                        <circle cx="12" cy="8" r="4"/>
                        <path d="M4 21c0-4 4-6 8-6s8 2 8 6"/>
                      </svg>
                    </div>
                  )}
                </div>
                <div class="player__body">
                  <div class="player__role">{r(p.role)} · {p.age} лет</div>
                  <div class="player__name">
                    <span class="player__first">{p.first}</span>
                    <span class="player__last">{p.last}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .team {
    padding: 120px 0 160px;
    background: #fafaf7;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), 0 100%);
  }

  .team__head {
    max-width: 720px;
    margin-bottom: 60px;
  }
  .team__title {
    font-family: 'Onest', sans-serif;
    font-size: clamp(48px, 7vw, 100px);
    font-weight: 900;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 24px;
  }
  .team__title span { color: #E4002B; }
  .team__lead {
    font-size: 16px;
    color: #4a4a4a;
    line-height: 1.7;
    max-width: 560px;
  }

  /* Staff */
  .staff {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-bottom: 90px;
  }
  .staff__card {
    background: #fff;
    border: 1px solid rgba(0,0,0,0.08);
    box-shadow: 0 8px 32px rgba(0,0,0,0.04);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(.25,.46,.45,.94);
  }
  .staff__card:hover {
    border-color: #E4002B;
    transform: translateY(-4px);
    box-shadow: 0 20px 50px rgba(228,0,43,0.18);
  }
  .staff__photo {
    aspect-ratio: 1;
    background: #f3f1ec;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .staff__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s ease;
  }
  .staff__card:hover .staff__photo img { transform: scale(1.03); }
  .staff__accent {
    position: absolute;
    bottom: 0; left: 0;
    width: 100px; height: 6px;
    background: #E4002B;
  }
  .placeholder { color: #c8c6bf; }
  .staff__body {
    padding: 22px 24px 26px;
  }
  .staff__role {
    font-family: 'Onest', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #E4002B;
    margin-bottom: 8px;
  }
  .staff__name {
    font-family: 'Onest', sans-serif;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: #0a0a0a;
    margin: 0;
  }
  .staff__bio {
    font-size: 13px;
    color: #6a6a6a;
    line-height: 1.55;
    margin: 12px 0 0;
  }

  /* Squad */
  .squad__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 36px;
    padding-bottom: 18px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
  }
  .squad__title {
    font-family: 'Onest', sans-serif;
    font-size: 26px;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0;
  }
  .squad__note {
    font-size: 12px;
    color: #6a6a6a;
    letter-spacing: 1.5px;
    margin: 0;
    text-transform: uppercase;
  }

  .group {
    margin-bottom: 48px;
  }
  .group__title {
    font-family: 'Onest', sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 18px;
    padding-left: 12px;
    border-left: 3px solid #E4002B;
  }
  .group__title span {
    color: #9a9a9a;
    font-weight: 500;
  }

  .squad__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .player {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08);
    transition: all 0.4s cubic-bezier(.25,.46,.45,.94);
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
  }
  .player:hover {
    border-color: #E4002B;
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(228,0,43,0.15);
  }
  .player__photo {
    position: relative;
    aspect-ratio: 3/4;
    background: linear-gradient(180deg, #f3f1ec 0%, #e8e5dc 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .player__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.5s ease;
  }
  .player:hover .player__photo img { transform: scale(1.04); }
  .player__num {
    position: absolute;
    top: 10px; right: 14px;
    font-family: 'Onest', sans-serif;
    font-weight: 900;
    font-size: 56px;
    color: rgba(255,255,255,0.95);
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    line-height: 1;
    z-index: 2;
  }
  .player__placeholder { color: #c8c6bf; }

  .player__body {
    padding: 14px 16px 16px;
    border-top: 2px solid #E4002B;
  }
  .player__role {
    font-family: 'Onest', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    color: #E4002B;
    margin-bottom: 4px;
    text-transform: uppercase;
  }
  .player__name {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .player__first {
    font-family: 'Onest', sans-serif;
    font-size: 12px;
    font-weight: 400;
    color: #6a6a6a;
  }
  .player__last {
    font-family: 'Onest', sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: #0a0a0a;
    letter-spacing: -0.01em;
  }

  @media (max-width: 900px) {
    .team { padding: 80px 0; }
    .staff { grid-template-columns: 1fr; gap: 16px; }
    .squad__grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
