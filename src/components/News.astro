---
const news = [
  {
    slug: 'pobeda-nad-olimp',
    date: '2026-04-12',
    dateText: '12 апреля',
    category: 'МАТЧ',
    title: 'Победа над «Олимпом» 2:1 на родном стадионе',
    excerpt: 'Непростая игра против крепкого соперника. Первый гол после быстрой контратаки, второй — с пенальти. Соперник отыгрался ближе к концу, но удержать счёт не смог.',
    featured: true,
    accent: '#E4002B',
  },
  {
    slug: 'novichki',
    date: '2026-04-08',
    dateText: '8 апреля',
    category: 'КОМАНДА',
    title: 'Пополнение в составе: два новых игрока',
    excerpt: 'В команде — полузащитник и нападающий из молодёжной сборной области.',
  },
  {
    slug: 'trenirovki',
    date: '2026-04-05',
    dateText: '5 апреля',
    category: 'КЛУБ',
    title: 'Открыты набор в детскую школу «Знамени»',
    excerpt: 'Принимаем мальчиков и девочек от 7 до 14 лет. Первые занятия — бесплатно.',
  },
  {
    slug: 'partner',
    date: '2026-04-02',
    dateText: '2 апреля',
    category: 'ПАРТНЁРЫ',
    title: 'Новый партнёр — ресторан «Морозов»',
    excerpt: 'Членам клуба — скидка 10% на весь заказ. Показываете карту — получаете скидку.',
  },
];
---
<section class="news" id="news">
  <div class="container-x">
    <div class="news__head reveal">
      <div class="sec-tag">Новости</div>
      <div class="news__head-row">
        <h2 class="news__title">ЖИЗНЬ<br/><span>КЛУБА</span></h2>
        <a href="#news" class="news__all">
          Все новости
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <div class="news__grid">
      <!-- FEATURED -->
      <article class="ncard ncard--featured reveal">
        <div class="ncard__image ncard__image--featured">
          <div class="ncard__placeholder">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <div class="ncard__score">2:1</div>
          <div class="ncard__gradient"></div>
        </div>
        <div class="ncard__body ncard__body--featured">
          <div class="ncard__meta">
            <span class="ncard__cat">{news[0].category}</span>
            <span class="ncard__date">{news[0].dateText}</span>
          </div>
          <h3 class="ncard__title ncard__title--featured">{news[0].title}</h3>
          <p class="ncard__excerpt">{news[0].excerpt}</p>
          <a href={`#news-${news[0].slug}`} class="ncard__link">
            Читать полностью
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </article>

      <!-- SMALL -->
      <div class="news__column">
        {news.slice(1).map((n, i) => (
          <article class="ncard reveal" style={`transition-delay: ${(i + 1) * 0.1}s`}>
            <div class="ncard__image ncard__image--small">
              <div class="ncard__placeholder ncard__placeholder--small">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.25">
                  <rect x="3" y="3" width="18" height="18" rx="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21,15 16,10 5,21"/>
                </svg>
              </div>
            </div>
            <div class="ncard__body">
              <div class="ncard__meta">
                <span class="ncard__cat">{n.category}</span>
                <span class="ncard__date">{n.dateText}</span>
              </div>
              <h3 class="ncard__title">{n.title}</h3>
              <p class="ncard__excerpt ncard__excerpt--small">{n.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .news {
    padding: 120px 0;
    background: #0a0a0a;
  }
  .news__head { margin-bottom: 48px; }
  .news__head-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    flex-wrap: wrap;
  }
  .news__title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #fff;
    margin: 0;
  }
  .news__title span { color: #E4002B; }

  .news__all {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border: 1px solid rgba(255,255,255,0.2);
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #d0d0d0;
    text-decoration: none;
    transition: all 0.3s;
    clip-path: polygon(0 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    padding-right: 32px;
  }
  .news__all:hover {
    border-color: #E4002B;
    color: #E4002B;
    transform: translateX(4px);
  }

  /* GRID */
  .news__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 24px;
    align-items: stretch;
  }

  .news__column {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* CARD */
  .ncard {
    background: #131313;
    border: 1px solid rgba(255,255,255,0.06);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(.25,.46,.45,.94);
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }
  .ncard:hover {
    border-color: rgba(228,0,43,0.5);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(228,0,43,0.12);
  }

  .ncard--featured {
    flex-direction: column;
  }

  /* IMAGE */
  .ncard__image {
    position: relative;
    background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .ncard__image--featured {
    aspect-ratio: 16/9;
    background:
      radial-gradient(circle at 70% 30%, rgba(228,0,43,0.3), transparent 60%),
      linear-gradient(135deg, #2a0010 0%, #0a0a0a 100%);
  }
  .ncard__image--small {
    flex-direction: row;
    aspect-ratio: 16/10;
  }
  .ncard:hover .ncard__image {
    background-color: #1f0008;
  }

  .ncard__placeholder {
    color: #2a2a2a;
    transition: transform 0.6s cubic-bezier(.25,.46,.45,.94);
  }
  .ncard:hover .ncard__placeholder { transform: scale(1.08); }

  .ncard__score {
    position: absolute;
    top: 20px; right: 24px;
    font-family: 'Oswald', sans-serif;
    font-weight: 700;
    font-size: 72px;
    color: #E4002B;
    letter-spacing: -0.02em;
    line-height: 1;
    text-shadow: 0 0 40px rgba(228,0,43,0.5);
  }

  .ncard__gradient {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50%;
    background: linear-gradient(180deg, transparent, rgba(10,10,10,0.8));
    pointer-events: none;
  }

  /* BODY */
  .ncard__body {
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .ncard__body--featured {
    padding: 32px 36px;
    gap: 14px;
  }

  .ncard__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ncard__cat {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    color: #E4002B;
    padding: 4px 9px;
    border: 1px solid rgba(228,0,43,0.35);
  }
  .ncard__date {
    font-size: 11px;
    color: #888;
    letter-spacing: 1px;
  }

  .ncard__title {
    font-family: 'Oswald', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #fff;
    margin: 0;
    transition: color 0.3s;
  }
  .ncard:hover .ncard__title { color: #E4002B; }
  .ncard__title--featured {
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .ncard__excerpt {
    font-size: 14px;
    color: #a8a8a8;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .ncard__excerpt--small {
    font-size: 13px;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    display: -webkit-box;
    overflow: hidden;
  }

  .ncard__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #E4002B;
    text-decoration: none;
    transition: gap 0.2s;
    margin-top: 4px;
  }
  .ncard__link:hover { gap: 14px; }

  @media (max-width: 900px) {
    .news { padding: 80px 0; }
    .news__grid { grid-template-columns: 1fr; }
    .ncard__body--featured { padding: 24px 22px; }
    .ncard__score { font-size: 54px; top: 14px; right: 18px; }
  }
</style>
