---
import { getCollection } from 'astro:content';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const newsUrl = (slug: string) => `${BASE}/news/${slug}/`;
const asset = (p: string) => `${BASE}${p.startsWith('/') ? p : '/' + p}`;

// 4 свежих новости одного размера. Без featured-выделения —
// заказчику проще: одна меньше — нет «дыры» от пустого закрепа.
const all = (await getCollection('news')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const items = all.slice(0, 4);

const fmtDate = (d: Date) =>
  new Intl.DateTimeFormat('ru-RU', { day: 'numeric', month: 'long' }).format(d);
---
{items.length > 0 && (
<section class="news" id="news">
  <div class="container-x">
    <div class="news__head reveal">
      <div class="sec-tag">Новости</div>
      <div class="news__head-row">
        <h2 class="news__title">ЖИЗНЬ<br/><span>КЛУБА</span></h2>
        <a href={`${BASE}/news/`} class="news__all">
          Все новости
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <div class="news__grid">
      {items.map((n, i) => (
        <a href={newsUrl(n.id)} class="ncard reveal" style={`transition-delay: ${i * 0.08}s`}>
          <div class="ncard__image">
            {n.data.image && (
              <img src={asset(n.data.image)} alt={n.data.title} class="ncard__img" loading="lazy" />
            )}
            {n.data.score && <div class="ncard__score">{n.data.score}</div>}
          </div>
          <div class="ncard__body">
            <div class="ncard__meta">
              <span class="ncard__cat">{n.data.category}</span>
              <span class="ncard__date">{fmtDate(n.data.date)}</span>
            </div>
            <h3 class="ncard__title">{n.data.title}</h3>
            <p class="ncard__excerpt">{n.data.excerpt}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .news {
    padding: 120px 0 160px;
    background: #fafaf7;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), 0 100%);
  }
  .news__head { margin-bottom: 48px; }
  .news__head-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 20px;
    flex-wrap: wrap;
  }
  .news__title {
    font-family: 'Onest', sans-serif;
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0;
  }
  .news__title span { color: #E4002B; }

  .news__all {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border: 1px solid rgba(0,0,0,0.18);
    font-family: 'Onest', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #2a2a2a;
    text-decoration: none;
    transition: all 0.3s;
    clip-path: polygon(0 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
    padding-right: 32px;
  }
  .news__all:hover {
    border-color: #E4002B;
    color: #E4002B;
    transform: translateX(4px);
  }

  /* GRID — 2×2 одинаковых карточек */
  .news__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    align-items: stretch;
  }

  /* CARD */
  .ncard {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08);
    overflow: hidden;
    transition: all 0.4s cubic-bezier(.25,.46,.45,.94);
    cursor: pointer;
    display: flex;
    flex-direction: column;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    text-decoration: none;
    color: inherit;
  }
  .ncard:hover {
    border-color: rgba(228,0,43,0.35);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(228,0,43,0.1);
  }

  /* IMAGE */
  .ncard__image {
    position: relative;
    aspect-ratio: 16/10;
    background: linear-gradient(135deg, #f3f1ec 0%, #e8e5dc 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .ncard:hover .ncard__image {
    background-color: #fff5f7;
  }

  .ncard__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(.25,.46,.45,.94);
  }
  .ncard:hover .ncard__img { transform: scale(1.04); }

  .ncard__score {
    position: absolute;
    top: 20px; right: 24px;
    font-family: 'Onest', sans-serif;
    font-weight: 700;
    font-size: 72px;
    color: #E4002B;
    letter-spacing: -0.02em;
    line-height: 1;
    text-shadow: 0 4px 20px rgba(228,0,43,0.25);
  }

  .ncard__gradient {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 50%;
    background: linear-gradient(180deg, transparent, rgba(255,255,255,0.6));
    pointer-events: none;
  }

  /* BODY */
  .ncard__body {
    padding: 24px 26px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
  }
  .ncard__body--featured {
    padding: 32px 36px;
    gap: 14px;
  }

  .ncard__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ncard__cat {
    font-family: 'Onest', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    color: #E4002B;
    padding: 4px 9px;
    border: 1px solid rgba(228,0,43,0.35);
    text-transform: uppercase;
  }
  .ncard__date {
    font-size: 11px;
    color: #6a6a6a;
    letter-spacing: 1px;
  }

  .ncard__title {
    font-family: 'Onest', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.25;
    color: #0a0a0a;
    margin: 0;
    transition: color 0.3s;
  }
  .ncard:hover .ncard__title { color: #E4002B; }
  .ncard__title--featured {
    font-size: clamp(22px, 2.4vw, 30px);
    line-height: 1.15;
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .ncard__excerpt {
    font-size: 14px;
    color: #4a4a4a;
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .ncard__excerpt--small {
    font-size: 13px;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    display: -webkit-box;
    overflow: hidden;
  }

  .ncard__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Onest', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #E4002B;
    text-decoration: none;
    transition: gap 0.2s;
    margin-top: 4px;
  }
  .ncard__link:hover { gap: 14px; }

  @media (max-width: 900px) {
    .news { padding: 80px 0; }
    .news__grid { grid-template-columns: 1fr; }
    .ncard__score { font-size: 54px; top: 14px; right: 18px; }
  }
</style>
