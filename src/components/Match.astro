---
import { getCollection } from 'astro:content';
import { fetchNextEvent, parseMatchTeams, isHomeMatch, formatMatchDate, formatMatchTime } from '../lib/timepad';

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
const LOGO = `${BASE}/logo.png`;
// Версия лого с белой обводкой для красных карточек (next match — красный фон)
const LOGO_ON_RED = `${BASE}/logo-on-red.png`;
const asset = (p: string) => `${BASE}${p.startsWith('/') ? p : '/' + p}`;

// Тянем следующий матч из TimePad. Если не получилось — fallback на хардкод.
const tpEvent = await fetchNextEvent();

// Логотипы соперников живут в коллекции opponents (src/content/opponents/*.md).
// Заказчик добавляет команды через Decap-админку: имя команды + файл лого.
// Match.astro ищет совпадение по имени (case-insensitive substring).
// Если команда найдена, но лого ещё не загружено — рисуется текстовая
// аббревиатура (как раньше). Это позволяет сразу заявить соперника, потом
// дозалить лого без правок кода.
const opponentEntries = await getCollection('opponents');

const opponentLogo = (teamName: string): string | null => {
  const lc = teamName.toLowerCase();
  const found = opponentEntries.find((e) =>
    lc.includes(e.data.name.toLowerCase()) || e.data.name.toLowerCase().includes(lc),
  );
  if (!found || !found.data.logo) return null;
  return asset(found.data.logo);
};

const fallbackNext = {
  league: 'ФФМО · Б-2',
  dateText: 'дата уточняется',
  time: '',
  homeName: 'Знамя Труда',
  homeCity: 'Орехово-Зуево',
  awayName: 'Соперник',
  awayCity: '',
  venue: 'Стадион «Знамя Труда», Орехово-Зуево',
  url: 'https://fczt.timepad.ru/',
  posterUrl: null as string | null,
};

let nextMatch = fallbackNext;
if (tpEvent) {
  const teams = parseMatchTeams(tpEvent.name);
  const home = teams ? teams.home : 'Знамя Труда';
  const away = teams ? teams.away : tpEvent.name;
  const homeIsKlub = isHomeMatch(tpEvent);
  const venue = [
    tpEvent.location.address,
    tpEvent.location.city,
  ].filter(Boolean).join(', ');

  nextMatch = {
    league: 'ФФМО · Б-2',
    dateText: formatMatchDate(tpEvent.startsAt),
    time: formatMatchTime(tpEvent.startsAt),
    homeName: homeIsKlub ? 'Знамя Труда' : home,
    homeCity: homeIsKlub ? 'Орехово-Зуево' : '',
    awayName: homeIsKlub ? away : 'Знамя Труда',
    awayCity: homeIsKlub ? '' : 'Орехово-Зуево',
    venue,
    url: tpEvent.url,
    posterUrl: tpEvent.posterUrl,
  };
}

// Последний матч редактируется вручную здесь.
// result: 'win' | 'draw' | 'loss' — определяет цвет бейджа.
const lastMatch = {
  league: 'ФФМО · Б-2 · 2 тур',
  date: '2026-05-02',
  dateText: '2 мая',
  home: { name: 'Кристалл-Восток', short: 'КРВ', score: 1 },
  away: { name: 'Знамя Труда',     short: 'ЗНМ', score: 1 },
  result: 'draw' as 'win' | 'draw' | 'loss',
};

const RESULT_LABELS = {
  win:  'ПОБЕДА',
  draw: 'НИЧЬЯ',
  loss: 'ПОРАЖЕНИЕ',
};

const isOurTeam = (name: string) => /знамя труда/i.test(name);

// Аббревиатура для команды без логотипа.
// «Кристалл-Восток» → «КВ» (по словам)
// «ФК НЕО» → «НЕО» (пропускаем «ФК»)
// «Сатурн-2» → «САТ» (одно слово → первые 3 буквы)
const shortName = (name: string) => {
  const words = name
    .replace(/[«»"']/g, '')
    .split(/[\s\-]+/)
    .filter((w) => w && !/^фк$/i.test(w));
  if (words.length >= 2) {
    return words.map((w) => w[0]).join('').toUpperCase().slice(0, 4);
  }
  return (words[0] || name).slice(0, 3).toUpperCase();
};
---
<section class="match" id="match">
  <div class="container-x">
    <div class="match__grid">
      <!-- NEXT -->
      <div class="match__card match__card--next reveal-left">
        <div class="match__tag">
          <span class="match__tag-dot"></span>
          Следующий матч
        </div>
        <div class="match__league">{nextMatch.league}</div>

        <div class="match__teams">
          <div class="team">
            {isOurTeam(nextMatch.homeName) ? (
              <div class="team__crest team__crest--logo">
                <img src={LOGO_ON_RED} alt={nextMatch.homeName} />
              </div>
            ) : opponentLogo(nextMatch.homeName) ? (
              <div class="team__crest team__crest--logo">
                <img src={opponentLogo(nextMatch.homeName)!} alt={nextMatch.homeName} />
              </div>
            ) : (
              <div class="team__crest">{shortName(nextMatch.homeName)}</div>
            )}
            <div class="team__name">{nextMatch.homeName}</div>
            {nextMatch.homeCity && <div class="team__city">{nextMatch.homeCity}</div>}
          </div>

          <div class="match__vs">
            <div class="match__date">{nextMatch.dateText}</div>
            {nextMatch.time && <div class="match__time">{nextMatch.time}</div>}
            <div class="match__vs-label">VS</div>
          </div>

          <div class="team">
            {isOurTeam(nextMatch.awayName) ? (
              <div class="team__crest team__crest--logo">
                <img src={LOGO_ON_RED} alt={nextMatch.awayName} />
              </div>
            ) : opponentLogo(nextMatch.awayName) ? (
              <div class="team__crest team__crest--logo">
                <img src={opponentLogo(nextMatch.awayName)!} alt={nextMatch.awayName} />
              </div>
            ) : (
              <div class="team__crest">{shortName(nextMatch.awayName)}</div>
            )}
            <div class="team__name">{nextMatch.awayName}</div>
            {nextMatch.awayCity && <div class="team__city">{nextMatch.awayCity}</div>}
          </div>
        </div>

        <div class="match__venue">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          {nextMatch.venue}
        </div>

        <a href={nextMatch.url} target="_blank" rel="noopener" class="btn btn--red match__cta">
          Зарегистрироваться на матч
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- LAST -->
      <div class="match__card match__card--last reveal-right">
        <div class="match__tag match__tag--muted">
          <span class="match__tag-dot match__tag-dot--muted"></span>
          Последний матч
        </div>
        <div class="match__league">{lastMatch.league}</div>

        <div class="match__score-row">
          <div class="score-team">
            {isOurTeam(lastMatch.home.name) ? (
              <div class="score-team__crest score-team__crest--logo">
                <img src={LOGO} alt={lastMatch.home.name} />
              </div>
            ) : opponentLogo(lastMatch.home.name) ? (
              <div class="score-team__crest score-team__crest--logo">
                <img src={opponentLogo(lastMatch.home.name)!} alt={lastMatch.home.name} />
              </div>
            ) : (
              <div class="score-team__crest">{lastMatch.home.short}</div>
            )}
            <div class="score-team__name">{lastMatch.home.name}</div>
          </div>
          <div class="score">
            <span class={`score__n ${lastMatch.result === 'win' ? 'score__n--win' : ''}`}>{lastMatch.home.score}</span>
            <span class="score__sep">:</span>
            <span class={`score__n ${lastMatch.result === 'loss' ? 'score__n--win' : ''}`}>{lastMatch.away.score}</span>
          </div>
          <div class="score-team score-team--right">
            {isOurTeam(lastMatch.away.name) ? (
              <div class="score-team__crest score-team__crest--logo">
                <img src={LOGO} alt={lastMatch.away.name} />
              </div>
            ) : opponentLogo(lastMatch.away.name) ? (
              <div class="score-team__crest score-team__crest--logo">
                <img src={opponentLogo(lastMatch.away.name)!} alt={lastMatch.away.name} />
              </div>
            ) : (
              <div class="score-team__crest">{lastMatch.away.short}</div>
            )}
            <div class="score-team__name">{lastMatch.away.name}</div>
          </div>
        </div>

        <div class="match__result">
          <span class={`result-badge result-badge--${lastMatch.result}`}>{RESULT_LABELS[lastMatch.result]}</span>
          <span class="match__date-small">{lastMatch.dateText}</span>
        </div>

        <a href="https://ffmo.ru/tournament43869/" target="_blank" rel="noopener" class="match__link">
          Турнирная таблица ФФМО
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17L17 7M8 7h9v9"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .match {
    padding: 80px 0;
    position: relative;
  }

  .match__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 24px;
  }

  .match__card {
    position: relative;
    padding: 36px;
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.08);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }
  .match__card--next {
    background: linear-gradient(135deg, #E4002B 0%, #8a0019 100%);
    border: 0;
    box-shadow: 0 20px 50px rgba(228,0,43,0.25);
  }
  .match__card--next::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(45deg, transparent 0, transparent 30px, rgba(255,255,255,0.03) 30px, rgba(255,255,255,0.03) 31px),
      radial-gradient(circle at 80% 20%, rgba(255,255,255,0.08) 0, transparent 50%);
    pointer-events: none;
  }
  .match__card--next > * { position: relative; z-index: 1; }

  .match__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'Onest', sans-serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }
  .match__tag-dot {
    width: 8px; height: 8px;
    background: #fff;
    border-radius: 50%;
    animation: pulse 1.8s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.4); }
  }
  .match__tag--muted { color: #6a6a6a; }
  .match__tag-dot--muted { background: #9a9a9a; animation: none; }

  .match__league {
    font-size: 12px;
    color: rgba(255,255,255,0.7);
    letter-spacing: 1.5px;
    margin-bottom: 32px;
  }
  .match__card--last .match__league { color: #6a6a6a; }
  .match__card--last .match__tag { color: #0a0a0a; }

  /* NEXT match teams */
  .match__teams {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    align-items: center;
    margin-bottom: 28px;
  }
  .team { text-align: center; }
  .team__crest {
    width: 72px; height: 84px;
    margin: 0 auto 14px;
    background: rgba(0,0,0,0.3);
    border: 2px solid rgba(255,255,255,0.2);
    clip-path: polygon(0 0, 100% 0, 100% 70%, 50% 100%, 0 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Onest', sans-serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 1px;
    color: #fff;
  }
  .team__crest--home {
    background: #fff;
    color: #E4002B;
    border-color: #fff;
  }
  .team__crest--logo {
    background: transparent;
    border: 0;
    clip-path: none;
    width: 84px; height: 84px;
  }
  .team__crest--logo img {
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
  }
  .team__name {
    font-family: 'Onest', sans-serif;
    font-size: 18px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #fff;
  }
  .team__city {
    font-size: 10px;
    color: rgba(255,255,255,0.6);
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  .match__vs {
    text-align: center;
    padding: 0 10px;
  }
  .match__date {
    font-family: 'Onest', sans-serif;
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: 4px;
  }
  .match__time {
    font-family: 'Onest', sans-serif;
    font-weight: 700;
    font-size: 36px;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1;
    margin-bottom: 8px;
  }
  .match__vs-label {
    font-family: 'Onest', sans-serif;
    font-weight: 400;
    font-size: 10px;
    letter-spacing: 3px;
    color: rgba(255,255,255,0.6);
  }

  .match__venue {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.5px;
    margin-bottom: 28px;
    padding-top: 18px;
    border-top: 1px solid rgba(255,255,255,0.15);
  }

  .match__cta {
    background: #fff;
    color: #E4002B;
  }
  .match__cta:hover {
    background: #0a0a0a;
    color: #fff;
    transform: translateX(4px);
  }

  /* LAST match */
  .match__score-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
  }
  .score-team { text-align: center; }
  .score-team--right { }
  .score-team__crest {
    width: 50px; height: 58px;
    margin: 0 auto 10px;
    background: rgba(228,0,43,0.1);
    border: 1.5px solid rgba(228,0,43,0.3);
    clip-path: polygon(0 0, 100% 0, 100% 70%, 50% 100%, 0 70%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Onest', sans-serif;
    font-weight: 700;
    font-size: 14px;
    color: #E4002B;
  }
  .score-team__crest--logo {
    background: transparent;
    border: 0;
    clip-path: none;
    width: 58px; height: 58px;
  }
  .score-team__crest--logo img {
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
  }
  .score-team__crest--home {
    background: #E4002B;
    border-color: #E4002B;
    color: #fff;
  }
  .score-team__name {
    font-family: 'Onest', sans-serif;
    font-size: 12px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #2a2a2a;
  }

  .score {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Onest', sans-serif;
  }
  .score__n {
    font-weight: 700;
    font-size: 44px;
    letter-spacing: -0.02em;
    color: #0a0a0a;
    line-height: 1;
  }
  .score__n--win { color: #E4002B; }
  .score__sep {
    font-weight: 400;
    font-size: 32px;
    color: #9a9a9a;
  }

  .match__result {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 20px 0;
    padding-top: 18px;
    border-top: 1px solid rgba(0,0,0,0.06);
  }
  .result-badge {
    padding: 4px 10px;
    border: 1px solid;
    font-family: 'Onest', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .result-badge--win {
    background: rgba(228,0,43,0.1);
    border-color: rgba(228,0,43,0.35);
    color: #E4002B;
  }
  .result-badge--draw {
    background: rgba(120,120,120,0.1);
    border-color: rgba(120,120,120,0.35);
    color: #555;
  }
  .result-badge--loss {
    background: rgba(70,70,70,0.08);
    border-color: rgba(70,70,70,0.3);
    color: #2a2a2a;
  }
  .match__date-small {
    font-size: 11px;
    color: #6a6a6a;
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  .match__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Onest', sans-serif;
    font-size: 12px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #E4002B;
    text-decoration: none;
    transition: gap 0.2s;
  }
  .match__link:hover { gap: 14px; }

  @media (max-width: 900px) {
    .match__grid { grid-template-columns: 1fr; }
    .match__card { padding: 28px 24px; }
    .match__teams { grid-template-columns: 1fr; gap: 20px; }
    .team__crest { width: 64px; height: 74px; }
  }
</style>
