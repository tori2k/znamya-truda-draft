---
---
<section class="contacts" id="contacts">
  <div class="container-x">
    <div class="contacts__grid">
      <div class="contacts__info reveal-left">
        <div class="sec-tag">Контакты</div>
        <h2 class="contacts__title">
          НАПИШИ<br/><span>НАМ</span>
        </h2>
        <p class="contacts__lead">
          Вопросы по членству, партнёрству, прессе — мы всегда на связи.
        </p>

        <div class="contacts__list">
          <a href="mailto:info@znamyatruda.ru" class="contact">
            <div class="contact__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="contact__text">
              <div class="contact__label">Email</div>
              <div class="contact__value">info@znamyatruda.ru</div>
            </div>
          </a>

          <a href="tel:+74964154500" class="contact">
            <div class="contact__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="contact__text">
              <div class="contact__label">Телефон</div>
              <div class="contact__value">+7 (496) 415-45-00</div>
            </div>
          </a>

          <div class="contact">
            <div class="contact__icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div class="contact__text">
              <div class="contact__label">Адрес</div>
              <div class="contact__value">Орехово-Зуево, стадион «Знамя Труда»</div>
            </div>
          </div>
        </div>

        <div class="contacts__social">
          <a href="#" class="social" aria-label="VK">VK</a>
          <a href="#" class="social" aria-label="Telegram">TG</a>
          <a href="#" class="social" aria-label="Instagram">IG</a>
          <a href="#" class="social" aria-label="YouTube">YT</a>
        </div>
      </div>

      <form class="form reveal-right" onsubmit="event.preventDefault(); alert('Форма отправки будет подключена к email/Telegram клуба.');">
        <h3 class="form__title">Напишите нам</h3>
        <label class="field">
          <span>Имя</span>
          <input type="text" name="name" required placeholder="Как к вам обращаться" />
        </label>
        <label class="field">
          <span>Контакт (Email или телефон)</span>
          <input type="text" name="contact" required placeholder="email или +7..." />
        </label>
        <label class="field">
          <span>Сообщение</span>
          <textarea name="msg" rows="4" required placeholder="О чём хотите спросить"></textarea>
        </label>
        <label class="agree">
          <input type="checkbox" required />
          <span>Согласен с обработкой персональных данных</span>
        </label>
        <button type="submit" class="btn btn--red">Отправить
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contacts {
    padding: 120px 0;
    background: #ffffff;
  }

  .contacts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }

  .contacts__title {
    font-family: 'Oswald', sans-serif;
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 20px;
  }
  .contacts__title span { color: #E4002B; }
  .contacts__lead {
    font-size: 16px;
    color: #4a4a4a;
    line-height: 1.7;
    margin: 0 0 40px;
    max-width: 460px;
  }

  .contacts__list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-bottom: 32px;
  }
  .contact {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    color: inherit;
    text-decoration: none;
    transition: padding-left 0.3s;
  }
  .contact[href]:hover { padding-left: 12px; color: #E4002B; }
  .contact__icon {
    width: 44px; height: 44px;
    background: rgba(228,0,43,0.08);
    border: 1px solid rgba(228,0,43,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #E4002B;
    flex-shrink: 0;
  }
  .contact__label {
    font-family: 'Oswald', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #6a6a6a;
    margin-bottom: 4px;
  }
  .contact__value {
    font-size: 15px;
    color: #0a0a0a;
    font-weight: 500;
  }

  .contacts__social {
    display: flex;
    gap: 10px;
  }
  .social {
    width: 44px; height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fafaf7;
    border: 1px solid rgba(0,0,0,0.1);
    color: #2a2a2a;
    font-family: 'Oswald', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .social:hover {
    background: #E4002B;
    color: #fff;
    border-color: #E4002B;
  }

  /* FORM */
  .form {
    padding: 40px;
    background: #fafaf7;
    border: 1px solid rgba(0,0,0,0.08);
  }
  .form__title {
    font-family: 'Oswald', sans-serif;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #0a0a0a;
    margin: 0 0 24px;
  }
  .field {
    display: flex;
    flex-direction: column;
    margin-bottom: 20px;
  }
  .field span {
    font-family: 'Oswald', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #6a6a6a;
    margin-bottom: 8px;
  }
  .field input, .field textarea {
    background: #ffffff;
    border: 1px solid rgba(0,0,0,0.12);
    padding: 12px 16px;
    color: #0a0a0a;
    font-family: inherit;
    font-size: 15px;
    outline: none;
    transition: border-color 0.3s;
    resize: vertical;
  }
  .field input::placeholder, .field textarea::placeholder { color: #a0a0a0; }
  .field input:focus, .field textarea:focus {
    border-color: #E4002B;
  }

  .agree {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: 13px;
    color: #6a6a6a;
    line-height: 1.5;
    margin-bottom: 24px;
    cursor: pointer;
  }
  .agree input { margin-top: 2px; accent-color: #E4002B; }

  @media (max-width: 900px) {
    .contacts { padding: 80px 0; }
    .contacts__grid { grid-template-columns: 1fr; gap: 50px; }
    .form { padding: 28px 24px; }
  }
</style>
