---
---
<section class="hero">
  <div class="hero__bg">
    <div class="hero__pattern"></div>
    <div class="hero__gradient"></div>
  </div>

  <div class="container-x hero__inner">
    <div class="hero__content">
      <div class="hero__meta reveal">
        <span class="hero__year">ЕСТЬ С 1909</span>
        <span class="hero__dot"></span>
        <span class="hero__city">ОРЕХОВО-ЗУЕВО</span>
      </div>

      <h1 class="hero__title reveal">
        <span class="hero__title-sub">ФУТБОЛЬНЫЙ КЛУБ</span>
        <span class="hero__title-main">ЗНАМЯ<br/>ТРУДА</span>
      </h1>

      <p class="hero__lead reveal">
        Старейший действующий футбольный клуб России. Финалист Кубка СССР 1962 года.
        Четырёхкратный чемпион Москвы. Более века в игре.
      </p>

      <div class="hero__actions reveal">
        <a href="#match" class="btn btn--red">Ближайший матч
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
        <a href="#history" class="btn btn--ghost">История клуба</a>
      </div>

      <div class="hero__stats reveal">
        <div class="stat">
          <div class="stat__n">117</div>
          <div class="stat__l">лет<br/>в футболе</div>
        </div>
        <div class="stat stat--accent">
          <div class="stat__n">1962</div>
          <div class="stat__l">финал<br/>Кубка СССР</div>
        </div>
        <div class="stat">
          <div class="stat__n">4×</div>
          <div class="stat__l">чемпион<br/>Москвы</div>
        </div>
        <div class="stat">
          <div class="stat__n">102K</div>
          <div class="stat__l">зрителей<br/>в Лужниках</div>
        </div>
      </div>
    </div>

    <div class="hero__visual reveal-right">
      <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/logo.png`} alt="ФК Знамя Труда" class="hero__logo" />
      <div class="hero__shield-glow"></div>
    </div>
  </div>

  <div class="hero__scroll">
    <span>SCROLL</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding: 120px 0 80px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, #ffffff 0%, #faf7f0 100%);
    z-index: 0;
  }
  .hero__pattern {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(135deg, rgba(228,0,43,0.05) 0%, transparent 40%),
      radial-gradient(circle at 80% 30%, rgba(228,0,43,0.08) 0%, transparent 50%),
      repeating-linear-gradient(-45deg, transparent 0, transparent 40px, rgba(0,0,0,0.015) 40px, rgba(0,0,0,0.015) 41px);
    opacity: 0.9;
  }
  .hero__gradient {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 30%;
    background: linear-gradient(180deg, transparent, #ffffff);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .hero__meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 8px 16px;
    background: rgba(228,0,43,0.08);
    border: 1px solid rgba(228,0,43,0.35);
    clip-path: polygon(0 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
    margin-bottom: 28px;
    font-family: 'Onest', sans-serif;
    font-size: 11px;
    letter-spacing: 2.5px;
    font-weight: 600;
    color: #E4002B;
  }
  .hero__dot {
    width: 4px; height: 4px;
    background: currentColor;
    border-radius: 50%;
  }

  .hero__title {
    margin: 0 0 30px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .hero__title-sub {
    font-family: 'Onest', sans-serif;
    font-size: clamp(14px, 1.6vw, 20px);
    letter-spacing: 8px;
    color: #6a6a6a;
    font-weight: 500;
  }
  .hero__title-main {
    font-family: 'Onest', sans-serif;
    font-size: clamp(64px, 10vw, 140px);
    font-weight: 700;
    line-height: 0.88;
    letter-spacing: -0.02em;
    color: #0a0a0a;
    text-transform: uppercase;
  }

  .hero__lead {
    font-size: clamp(15px, 1.4vw, 18px);
    color: #4a4a4a;
    line-height: 1.65;
    max-width: 560px;
    margin: 0 0 36px;
  }

  .hero__actions {
    display: flex;
    gap: 14px;
    margin-bottom: 60px;
    flex-wrap: wrap;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    padding-top: 30px;
    border-top: 1px solid rgba(0,0,0,0.1);
    max-width: 620px;
  }
  .stat { display: flex; flex-direction: column; gap: 6px; }
  .stat__n {
    font-family: 'Onest', sans-serif;
    font-weight: 700;
    font-size: clamp(28px, 3.2vw, 40px);
    letter-spacing: -0.02em;
    color: #0a0a0a;
    line-height: 1;
  }
  .stat--accent .stat__n { color: #E4002B; }
  .stat__l {
    font-size: 11px;
    color: #6a6a6a;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    line-height: 1.3;
  }

  /* SHIELD */
  .hero__visual {
    position: relative;
    aspect-ratio: 1/1.2;
    max-width: 440px;
    justify-self: end;
  }
  .hero__logo {
    position: relative;
    width: 100%;
    max-width: 480px;
    height: auto;
    object-fit: contain;
    z-index: 2;
    filter: drop-shadow(0 30px 60px rgba(228,0,43,0.25));
    animation: hero-float 6s ease-in-out infinite;
  }
  @keyframes hero-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }
  .hero__shield-glow {
    position: absolute;
    top: 20%; left: 20%;
    width: 60%; height: 60%;
    background: #E4002B;
    filter: blur(100px);
    opacity: 0.25;
    z-index: 1;
    pointer-events: none;
  }

  .hero__scroll {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    font-family: 'Onest', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    color: #6a6a6a;
    z-index: 3;
    animation: bounce 2.5s ease-in-out infinite;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  @media (max-width: 1000px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero__visual { max-width: 320px; justify-self: center; }
    .hero__stats { grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .hero__scroll { display: none; }
  }
  @media (max-width: 500px) {
    .hero { padding: 100px 0 60px; }
    .hero__stats { gap: 16px; }
  }
</style>

<script>
  (() => {
    const bg = document.querySelector('.hero__bg, .hero__shield-glow') as HTMLElement | null;
    if (!bg) return;
    let ticking = false;
    const update = () => {
      const y = window.scrollY;
      bg.style.transform = `translateY(${y * 0.3}px)`;
      ticking = false;
    };
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>
